{
  "name": "frisbee-tactics-board",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "npm run styles && concurrently -k \"chokidar 'styles/**/*.less' -c 'npm run styles'\" \"next dev\"",
    "build": "npm run styles && next build",
    "start": "next start",
    "styles": "lessc styles/index.less app/generated.css",
    "lint": "eslint .",
    "db:init": "node --env-file=.env.local scripts/init-db.mjs"
  },
  "dependencies": {
    "lucide-react": "1.22.0",
    "next": "16.2.9",
    "postgres": "3.4.9",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "chokidar-cli": "3.0.0",
    "concurrently": "9.2.1",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.9",
    "less": "4.6.7"
  }
}
